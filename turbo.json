{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "pipeline": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".astro/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "build-pdfs": {
      "outputs": ["apps/portal/public/pdfs/**"],
      "inputs": ["content/drive-sync/**/*.md", "packages/pdf-builder/**"]
    }
  }
}